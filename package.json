{
  "name": "opencode-architect",
  "version": "0.2.0",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "bun build index.ts --outdir dist --format esm --target node --dts",
    "prepublishOnly": "bun run build",
    "release": "npm version patch && npm publish && git push --follow-tags"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@opencode-ai/plugin": "^1.2.25"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
